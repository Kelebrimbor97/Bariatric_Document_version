# Copy to .env (or export in shell) and adjust for your machine.

# Base model weights directory used by config defaults.
# If omitted, defaults to ../LLM_Weights relative to repo root.
LLM_WEIGHTS_DIR=/absolute/path/to/LLM_Weights

# LLM (vLLM container) model path + served name.
# Inside container, this path should point to mounted /llm_weights/*.
VLLM_MODEL_PATH=/llm_weights/Qwen3.6-35B-A3B
VLLM_MODEL_NAME=qwen-ehr

# Optional explicit model overrides (otherwise derived from LLM_WEIGHTS_DIR)
# MEDCPT_QUERY_MODEL=/absolute/path/to/LLM_Weights/MedCPT-Query-Encoder
# MEDCPT_ARTICLE_MODEL=/absolute/path/to/LLM_Weights/MedCPT-Article-Encoder
# MEDCPT_RERANK_MODEL=/absolute/path/to/LLM_Weights/MedCPT-Cross-Encoder
# HF_CACHE_DIR=/absolute/path/to/LLM_Weights

# VLM (BioMedCLIP) model artifacts for scripts that use BiomedCLIP.
# BIOMEDCLIP_CKPT_DIR=/absolute/path/to/LLM_Weights/BiomedCLIP-PubMedBERT_256-vit_base_patch16_224
# BIOMEDBERT_TOKENIZER_PATH=/absolute/path/to/LLM_Weights/BiomedNLP-BiomedBERT-base-uncased-abstract

# Optional runtime services
# QDRANT_URL=http://localhost:6333
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL_NAME=qwen-ehr
# ENCODER_API_URL=http://localhost:8092

# Optional data roots
# DATA_DIR=/absolute/path/to/Data
# PATIENTS_ROOT=/absolute/path/to/Data/MBS LLM/Test Patients
